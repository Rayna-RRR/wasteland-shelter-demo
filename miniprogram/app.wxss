page {
  min-height: 100vh;
  background: #f3efe4;
  color: #24201c;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 36rpx 28rpx 60rpx;
}

.header {
  margin-bottom: 30rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #d5c6ae;
}

.title {
  display: block;
  color: #263238;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: #665f55;
  font-size: 28rpx;
  line-height: 1.5;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  display: block;
  margin-bottom: 18rpx;
  color: #3c352d;
  font-size: 30rpx;
  font-weight: 700;
}

.card {
  box-sizing: border-box;
  padding: 24rpx 26rpx;
  border: 1rpx solid #d7cbbd;
  border-left: 6rpx solid #7d8f83;
  border-radius: 8rpx;
  background: #fffdf7;
}

.result-card {
  border-left-color: #b7863b;
}

.message-card {
  box-sizing: border-box;
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #e0c9b2;
  border-left: 6rpx solid #b7863b;
  border-radius: 8rpx;
  background: #fff7ed;
}

.muted {
  display: block;
  color: #7a7167;
  font-size: 26rpx;
  line-height: 1.5;
}

.entity-title {
  display: block;
  margin-bottom: 12rpx;
  color: #263238;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.field-row {
  display: block;
  margin-top: 10rpx;
  color: #3f3932;
  font-size: 28rpx;
  line-height: 1.5;
}

.resource-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.resource-item {
  box-sizing: border-box;
  width: calc(50% - 8rpx);
  min-height: 128rpx;
  padding: 22rpx;
  border: 1rpx solid #d7cbbd;
  border-radius: 8rpx;
  background: #fffdf7;
}

.resource-label {
  display: block;
  color: #6d6257;
  font-size: 26rpx;
}

.resource-value {
  display: block;
  margin-top: 10rpx;
  color: #263238;
  font-size: 38rpx;
  font-weight: 700;
}

.action-button {
  margin-top: 20rpx;
  border-radius: 8rpx;
  background: #1f6f68;
  color: #ffffff;
  font-size: 30rpx;
}

.action-button[disabled] {
  background: #91aaa5;
  color: #ffffff;
}

.nav-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.nav-card {
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  border: 1rpx solid #c8d8d2;
  border-left: 6rpx solid #7d8f83;
  border-radius: 8rpx;
  background: #eef6f3;
  color: #1f524c;
  font-size: 30rpx;
  font-weight: 600;
}

.nav-card--active {
  background: #dceee8;
}
