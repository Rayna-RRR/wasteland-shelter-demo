page {
  --base-background: #1A1A1A;
  --base-text: #D3D3D3;
  --muted-text: #9b9286;
  --panel-background: rgba(18, 17, 16, 0.88);
  --panel-border: rgba(193, 154, 107, 0.30);
  --metal-dark: #242220;
  --metal-light: #5f5a52;
  --rust-red: #8B3A3A;
  --desert-yellow: #C19A6B;
  --radiation-green: #39FF14;
  --hazard-orange: #FF5722;

  min-height: 100vh;
  background-color: var(--base-background);
  background-image:
    radial-gradient(circle at 18% 0%, rgba(193, 154, 107, 0.13) 0%, transparent 34%),
    radial-gradient(circle at 84% 6%, rgba(139, 58, 58, 0.18) 0%, transparent 34%),
    linear-gradient(180deg, #1A1A1A 0%, #11100f 56%, #070707 100%);
  color: var(--base-text);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 36rpx 28rpx 60rpx;
  background: transparent;
}

.header {
  margin-bottom: 30rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(193, 154, 107, 0.42);
}

.title {
  display: block;
  color: var(--base-text);
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.3;
  text-shadow: 0 0 14rpx rgba(193, 154, 107, 0.18);
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: var(--desert-yellow);
  font-size: 28rpx;
  line-height: 1.5;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  display: block;
  margin-bottom: 18rpx;
  color: var(--desert-yellow);
  font-size: 30rpx;
  font-weight: 700;
}

.card {
  box-sizing: border-box;
  padding: 24rpx 26rpx;
  border: 1rpx solid var(--panel-border);
  border-left: 6rpx solid var(--rust-red);
  border-radius: 8rpx;
  background: var(--panel-background);
  box-shadow: 0 12rpx 34rpx rgba(0, 0, 0, 0.32);
}

.result-card {
  border-left-color: var(--hazard-orange);
  box-shadow: 0 0 28rpx rgba(255, 87, 34, 0.12), 0 12rpx 34rpx rgba(0, 0, 0, 0.32);
}

.message-card {
  box-sizing: border-box;
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(255, 87, 34, 0.34);
  border-left: 6rpx solid var(--hazard-orange);
  border-radius: 8rpx;
  background: rgba(139, 58, 58, 0.18);
}

.muted {
  display: block;
  color: rgba(211, 211, 211, 0.78);
  font-size: 26rpx;
  line-height: 1.5;
}

.entity-title {
  display: block;
  margin-bottom: 12rpx;
  color: var(--base-text);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.field-row {
  display: block;
  margin-top: 10rpx;
  color: rgba(211, 211, 211, 0.9);
  font-size: 28rpx;
  line-height: 1.5;
}

.resource-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.resource-item {
  box-sizing: border-box;
  width: calc(50% - 8rpx);
  min-height: 128rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.34);
  border-radius: 8rpx;
  background: rgba(12, 12, 12, 0.78);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.03);
}

.resource-label {
  display: block;
  color: var(--desert-yellow);
  font-size: 26rpx;
}

.resource-value {
  display: block;
  margin-top: 10rpx;
  color: var(--radiation-green);
  font-size: 38rpx;
  font-weight: 700;
  text-shadow: 0 0 12rpx rgba(57, 255, 20, 0.26);
}

.action-button {
  margin-top: 20rpx;
  border: 1rpx solid rgba(57, 255, 20, 0.34);
  border-radius: 8rpx;
  background: linear-gradient(90deg, var(--rust-red), #4f2323);
  color: var(--base-text);
  font-size: 30rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.28);
}

.action-button--active {
  opacity: 0.9;
  transform: translateY(2rpx);
}

.action-button[disabled] {
  border-color: rgba(211, 211, 211, 0.16);
  background: #343434;
  color: rgba(211, 211, 211, 0.58);
  box-shadow: none;
}

button::after {
  border: none;
}

.nav-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.nav-card {
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.32);
  border-left: 6rpx solid var(--desert-yellow);
  border-radius: 8rpx;
  background: rgba(18, 18, 18, 0.78);
  color: var(--base-text);
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.22);
}

.nav-card--active {
  border-left-color: var(--radiation-green);
  background: rgba(57, 255, 20, 0.08);
  transform: translateX(4rpx);
}

.global-noise-overlay {
  pointer-events: none;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  opacity: 0.08;
  background-image:
    repeating-linear-gradient(0deg, rgba(211, 211, 211, 0.08) 0, rgba(211, 211, 211, 0.08) 1rpx, transparent 1rpx, transparent 10rpx),
    repeating-linear-gradient(90deg, rgba(193, 154, 107, 0.04) 0, rgba(193, 154, 107, 0.04) 1rpx, transparent 1rpx, transparent 24rpx);
}
