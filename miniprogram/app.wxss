page {
  --base-background: #1A1A1A;
  --base-text: #D3D3D3;
  --muted-text: #9b9286;
  --panel-background: rgba(18, 17, 16, 0.88);
  --panel-border: rgba(193, 154, 107, 0.30);
  --metal-dark: #242220;
  --metal-light: #5f5a52;
  --rust-red: #8B3A3A;
  --desert-yellow: #C19A6B;
  --radiation-green: #39FF14;
  --hazard-orange: #FF5722;

  min-height: 100vh;
  background-color: #100f0e;
  background-image:
    radial-gradient(circle at 18% 0%, rgba(193, 154, 107, 0.11) 0%, rgba(193, 154, 107, 0) 42%),
    radial-gradient(circle at 84% 6%, rgba(139, 58, 58, 0.14) 0%, rgba(139, 58, 58, 0) 40%),
    linear-gradient(180deg, #1A1A1A 0%, #151311 58%, #100f0e 100%);
  background-attachment: fixed;
  background-repeat: no-repeat;
  background-size: cover;
  color: var(--base-text);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 36rpx 28rpx 60rpx;
  background: transparent;
}

.header {
  margin-bottom: 30rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(193, 154, 107, 0.42);
}

.title {
  display: block;
  color: var(--base-text);
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.3;
  text-shadow: 0 0 14rpx rgba(193, 154, 107, 0.18);
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: var(--desert-yellow);
  font-size: 28rpx;
  line-height: 1.5;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  display: block;
  margin-bottom: 18rpx;
  color: var(--desert-yellow);
  font-size: 30rpx;
  font-weight: 700;
}

.card {
  box-sizing: border-box;
  padding: 24rpx 26rpx;
  border: 1rpx solid var(--panel-border);
  border-left: 6rpx solid var(--rust-red);
  border-radius: 8rpx;
  background: var(--panel-background);
  box-shadow: 0 12rpx 34rpx rgba(0, 0, 0, 0.32);
}

.result-card {
  border-left-color: var(--hazard-orange);
  box-shadow: 0 0 28rpx rgba(255, 87, 34, 0.12), 0 12rpx 34rpx rgba(0, 0, 0, 0.32);
}

.message-card {
  box-sizing: border-box;
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(255, 87, 34, 0.34);
  border-left: 6rpx solid var(--hazard-orange);
  border-radius: 8rpx;
  background: rgba(139, 58, 58, 0.18);
}

.muted {
  display: block;
  color: rgba(211, 211, 211, 0.78);
  font-size: 26rpx;
  line-height: 1.5;
}

.entity-title {
  display: block;
  margin-bottom: 12rpx;
  color: var(--base-text);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.survivor-portrait {
  position: relative;
  box-sizing: border-box;
  display: flex;
  flex: 0 0 96rpx;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  overflow: hidden;
  border: 1rpx solid rgba(193, 154, 107, 0.34);
  border-radius: 8rpx;
  background:
    linear-gradient(135deg, rgba(193, 154, 107, 0.18), transparent 56%),
    rgba(0, 0, 0, 0.30);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.03);
}

.survivor-portrait--compact {
  flex-basis: 84rpx;
  width: 84rpx;
  height: 84rpx;
}

.survivor-portrait--featured {
  flex-basis: 116rpx;
  width: 116rpx;
  height: 116rpx;
}

.survivor-portrait--recruit {
  flex-basis: 132rpx;
  width: 132rpx;
  height: 132rpx;
}

.survivor-portrait--home {
  flex-basis: 86rpx;
  width: 86rpx;
  height: 86rpx;
}

.survivor-portrait--ssr {
  border-color: rgba(255, 87, 34, 0.52);
  background:
    linear-gradient(135deg, rgba(255, 87, 34, 0.22), transparent 58%),
    rgba(0, 0, 0, 0.30);
}

.survivor-portrait--sr {
  border-color: rgba(193, 154, 107, 0.52);
}

.survivor-portrait--r {
  border-color: rgba(95, 90, 82, 0.58);
}

.survivor-portrait-image {
  display: block;
  width: 100%;
  height: 100%;
}

.survivor-portrait-fallback {
  display: block;
  box-sizing: border-box;
  width: 100%;
  padding: 0 8rpx;
  color: var(--base-text);
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
}

.survivor-portrait--recruit .survivor-portrait-fallback {
  font-size: 34rpx;
}

.survivor-portrait--featured .survivor-portrait-fallback {
  font-size: 31rpx;
}

.survivor-portrait--compact .survivor-portrait-fallback,
.survivor-portrait--home .survivor-portrait-fallback {
  font-size: 24rpx;
}

.survivor-portrait-fallback--ssr {
  color: var(--hazard-orange);
  text-shadow: 0 0 14rpx rgba(255, 87, 34, 0.24);
}

.survivor-portrait-fallback--sr {
  color: var(--desert-yellow);
}

.survivor-card {
  position: relative;
  box-sizing: border-box;
  overflow: hidden;
  padding: 22rpx 24rpx 24rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.36);
  border-left: 6rpx solid var(--rust-red);
  border-radius: 8rpx;
  background: rgba(18, 18, 18, 0.82);
  box-shadow: 0 12rpx 34rpx rgba(0, 0, 0, 0.28);
}

.survivor-card::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: rgba(193, 154, 107, 0.36);
}

.survivor-card--ssr {
  border-color: rgba(255, 87, 34, 0.42);
  border-left-color: var(--hazard-orange);
  background:
    linear-gradient(135deg, rgba(255, 87, 34, 0.12), transparent 42%),
    rgba(18, 18, 18, 0.86);
}

.survivor-card--sr {
  border-color: rgba(193, 154, 107, 0.44);
  border-left-color: var(--desert-yellow);
  background:
    linear-gradient(135deg, rgba(193, 154, 107, 0.12), transparent 42%),
    rgba(18, 18, 18, 0.84);
}

.survivor-card--r {
  border-color: rgba(95, 90, 82, 0.52);
  border-left-color: var(--metal-light);
}

.survivor-card--ssr::after {
  background: var(--hazard-orange);
}

.survivor-card--sr::after {
  background: var(--desert-yellow);
}

.survivor-card--r::after {
  background: var(--metal-light);
}

.survivor-card--home {
  padding: 18rpx;
}

.survivor-card--featured {
  padding: 24rpx 26rpx 26rpx;
  border-left-width: 8rpx;
  box-shadow: 0 0 38rpx rgba(193, 154, 107, 0.10), 0 18rpx 44rpx rgba(0, 0, 0, 0.34);
}

.survivor-card--selected {
  border-color: rgba(57, 255, 20, 0.58);
  border-left-color: var(--radiation-green);
  background:
    linear-gradient(135deg, rgba(57, 255, 20, 0.10), transparent 48%),
    rgba(18, 18, 18, 0.90);
  transform: translateY(-2rpx);
  box-shadow: 0 0 40rpx rgba(57, 255, 20, 0.18), 0 14rpx 36rpx rgba(0, 0, 0, 0.34);
}

.survivor-card--selected::after {
  background: var(--radiation-green);
}

.survivor-card--unavailable {
  opacity: 0.62;
  border-color: rgba(155, 146, 134, 0.30);
  border-left-color: rgba(155, 146, 134, 0.68);
  background:
    linear-gradient(135deg, rgba(95, 90, 82, 0.16), transparent 46%),
    rgba(18, 18, 18, 0.76);
}

.survivor-card--unavailable::after {
  background: rgba(155, 146, 134, 0.54);
}

.survivor-identity-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  min-width: 0;
}

.survivor-identity-row--home {
  align-items: center;
  gap: 16rpx;
}

.survivor-identity-row--recruit,
.survivor-identity-row--featured {
  align-items: flex-start;
}

.survivor-identity-main {
  flex: 1;
  min-width: 0;
}

.survivor-display-name {
  display: block;
  color: var(--base-text);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow-wrap: anywhere;
  text-shadow: 0 0 14rpx rgba(193, 154, 107, 0.16);
}

.survivor-display-name--compact {
  font-size: 31rpx;
}

.survivor-display-name--featured {
  font-size: 42rpx;
  line-height: 1.18;
}

.survivor-display-name--recruit {
  margin-top: 6rpx;
  font-size: 54rpx;
  line-height: 1.15;
  text-shadow: 0 0 18rpx rgba(193, 154, 107, 0.20);
}

.survivor-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
  min-width: 0;
}

.survivor-tag {
  display: inline-block;
  box-sizing: border-box;
  max-width: 240rpx;
  min-height: 38rpx;
  padding: 5rpx 14rpx;
  overflow: hidden;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 28rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.survivor-rarity-tag--ssr {
  border: 1rpx solid rgba(255, 87, 34, 0.48);
  background: rgba(255, 87, 34, 0.14);
  color: var(--hazard-orange);
}

.survivor-rarity-tag--sr {
  border: 1rpx solid rgba(193, 154, 107, 0.48);
  background: rgba(193, 154, 107, 0.12);
  color: var(--desert-yellow);
}

.survivor-rarity-tag--r {
  border: 1rpx solid rgba(95, 90, 82, 0.56);
  background: rgba(95, 90, 82, 0.12);
  color: var(--muted-text);
}

.survivor-role-tag {
  border: 1rpx solid rgba(193, 154, 107, 0.28);
  background: rgba(0, 0, 0, 0.22);
  color: rgba(211, 211, 211, 0.84);
}

.survivor-status-tag {
  display: inline-block;
  box-sizing: border-box;
  max-width: 190rpx;
  min-height: 40rpx;
  padding: 5rpx 14rpx;
  overflow: hidden;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 30rpx;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.survivor-status-tag--good {
  border: 1rpx solid rgba(57, 255, 20, 0.36);
  background: rgba(57, 255, 20, 0.10);
  color: var(--radiation-green);
}

.survivor-status-tag--warning {
  border: 1rpx solid rgba(255, 87, 34, 0.38);
  background: rgba(255, 87, 34, 0.12);
  color: var(--hazard-orange);
}

.survivor-status-tag--danger {
  border: 1rpx solid rgba(255, 106, 106, 0.46);
  background: rgba(139, 58, 58, 0.26);
  color: #ff6a6a;
}

.survivor-trait-line,
.trait-callout {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.26);
  border-radius: 8rpx;
  background:
    linear-gradient(90deg, rgba(193, 154, 107, 0.12), transparent),
    rgba(0, 0, 0, 0.20);
}

.trait-callout {
  margin-top: 18rpx;
  padding: 15rpx 18rpx;
}

.trait-callout--compact {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
}

.survivor-trait-label,
.trait-kicker {
  box-sizing: border-box;
  flex: 0 0 auto;
  min-width: 76rpx;
  padding: 4rpx 10rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.24);
  border-radius: 8rpx;
  color: var(--desert-yellow);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 30rpx;
  text-align: center;
}

.survivor-trait-value,
.trait-value {
  flex: 1;
  min-width: 0;
  color: var(--base-text);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow-wrap: anywhere;
}

.survivor-vitals-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 16rpx;
}

.survivor-vitals-row--compact {
  margin-top: 14rpx;
}

.survivor-vital {
  box-sizing: border-box;
  min-height: 42rpx;
  padding: 6rpx 12rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.22);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.18);
  color: rgba(211, 211, 211, 0.84);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 30rpx;
  text-align: center;
}

.survivor-vital--warning {
  border-color: rgba(255, 87, 34, 0.34);
  background: rgba(255, 87, 34, 0.10);
  color: var(--hazard-orange);
}

.survivor-vital--danger {
  border-color: rgba(255, 106, 106, 0.44);
  background: rgba(139, 58, 58, 0.22);
  color: #ff6a6a;
}

.state-panel {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.28);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.22);
}

.state-panel--compact {
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
}

.state-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 44rpx;
}

.state-row + .state-row {
  margin-top: 10rpx;
}

.state-label {
  box-sizing: border-box;
  min-width: 92rpx;
  color: var(--desert-yellow);
  font-size: 26rpx;
  font-weight: 700;
}

.state-value {
  min-width: 72rpx;
  color: var(--base-text);
  font-size: 30rpx;
  font-weight: 700;
  text-align: right;
}

.state-value--warning {
  color: var(--hazard-orange);
}

.state-value--danger {
  color: #ff6a6a;
}

.field-row {
  display: block;
  margin-top: 10rpx;
  color: rgba(211, 211, 211, 0.9);
  font-size: 28rpx;
  line-height: 1.5;
}

.resource-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.resource-item {
  box-sizing: border-box;
  width: calc(50% - 8rpx);
  min-height: 128rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.34);
  border-radius: 8rpx;
  background: rgba(12, 12, 12, 0.78);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.03);
}

.resource-label {
  display: block;
  color: var(--desert-yellow);
  font-size: 26rpx;
}

.resource-value {
  display: block;
  margin-top: 10rpx;
  color: var(--radiation-green);
  font-size: 38rpx;
  font-weight: 700;
  text-shadow: 0 0 12rpx rgba(57, 255, 20, 0.26);
}

.action-button {
  margin-top: 20rpx;
  border: 1rpx solid rgba(57, 255, 20, 0.34);
  border-radius: 8rpx;
  background: linear-gradient(90deg, var(--rust-red), #4f2323);
  color: var(--base-text);
  font-size: 30rpx;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.28);
}

.action-button--active {
  opacity: 0.9;
  transform: translateY(2rpx);
}

.action-button[disabled] {
  border-color: rgba(211, 211, 211, 0.16);
  background: #343434;
  color: rgba(211, 211, 211, 0.58);
  box-shadow: none;
}

button::after {
  border: none;
}

.nav-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.nav-card {
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.32);
  border-left: 6rpx solid var(--desert-yellow);
  border-radius: 8rpx;
  background: rgba(18, 18, 18, 0.78);
  color: var(--base-text);
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.22);
}

.nav-card--active {
  border-left-color: var(--radiation-green);
  background: rgba(57, 255, 20, 0.08);
  transform: translateX(4rpx);
}

.global-noise-overlay {
  pointer-events: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 100vh;
  z-index: 0;
  opacity: 0.035;
  background-image:
    linear-gradient(115deg, rgba(193, 154, 107, 0.05), transparent 42%, rgba(139, 58, 58, 0.045)),
    repeating-linear-gradient(90deg, rgba(193, 154, 107, 0.03) 0, rgba(193, 154, 107, 0.03) 1rpx, transparent 1rpx, transparent 32rpx);
}
