<view class="page">
  <view class="global-noise-overlay"></view>
  <view class="header">
    <text class="title">值勤调度</text>
    <text class="subtitle">安排幸存者任务</text>
  </view>

  <view class="section">
    <text class="section-title">当前资源</text>
    <view class="resource-grid page-resource-grid">
      <view class="resource-item">
        <text class="resource-label">食物</text>
        <text class="resource-value">{{resources.food}}</text>
      </view>
      <view class="resource-item">
        <text class="resource-label">电力</text>
        <text class="resource-value">{{resources.power}}</text>
      </view>
      <view class="resource-item">
        <text class="resource-label">材料</text>
        <text class="resource-value">{{resources.materials}}</text>
      </view>
      <view class="resource-item">
        <text class="resource-label">招募券</text>
        <text class="resource-value">{{resources.premium_currency}}</text>
      </view>
    </view>
    <view wx:if="{{loadingResources}}" class="message-card">
      <text class="muted">资源刷新中...</text>
    </view>
    <view wx:if="{{hasRunState}}" class="resource-grid page-resource-grid run-state-grid">
      <view class="resource-item">
        <text class="resource-label">当前天数</text>
        <text class="resource-value">{{runState.current_day}} / {{runState.total_days}}</text>
      </view>
      <view class="resource-item">
        <text class="resource-label">今日行动</text>
        <text class="resource-value">{{runState.actions_left}} / {{runState.actions_per_day}}</text>
      </view>
      <view class="resource-item resource-item--wide">
        <text class="resource-label">威胁倒计时</text>
        <text class="resource-value">{{runState.threat_days_left}}</text>
      </view>
    </view>
    <view wx:if="{{hasPendingEvent}}" class="message-card">
      <text class="muted">今日随机事件未处理，请先回首页完成选择。</text>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="section">
    <view class="message-card">
      <text class="muted">{{errorMessage}}</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">派遣名单</text>
    <view wx:if="{{loadingSurvivors}}" class="card">
      <text class="muted">幸存者加载中...</text>
    </view>
    <block wx:elif="{{survivorGroups.length}}">
      <view wx:for="{{survivorGroups}}" wx:for-item="group" wx:key="key" class="{{group.groupClass}}">
        <view
          class="dispatch-group-header"
          hover-class="dispatch-group-header--active"
          hover-stay-time="80"
          data-group-key="{{group.key}}"
          bindtap="toggleRarityGroup"
        >
          <view class="dispatch-group-title-wrap">
            <text class="dispatch-group-title">{{group.label}}</text>
            <text wx:if="{{group.selectedInGroup}}" class="dispatch-group-selected">{{group.selectedSummary}}</text>
          </view>
          <view class="dispatch-group-meta">
            <text class="dispatch-group-count">{{group.summaryText}}</text>
            <text class="dispatch-group-toggle">{{group.toggleText}} {{group.toggleIndicator}}</text>
          </view>
        </view>
        <view wx:if="{{!group.collapsed}}" class="dispatch-roster-list">
          <view
            wx:for="{{group.survivors}}"
            wx:for-item="survivor"
            wx:key="id"
            class="{{survivor.cardClass}}"
            hover-class="survivor-card--hover"
            hover-stay-time="80"
            data-survivor-id="{{survivor.id}}"
            bindtap="selectSurvivor"
          >
            <text wx:if="{{survivor.selected}}" class="selected-ribbon">已选择</text>
            <view class="survivor-identity-row">
              <view class="{{survivor.portraitFrameClass}} survivor-portrait--compact">
                <image wx:if="{{survivor.hasPortrait}}" class="survivor-portrait-image" src="{{survivor.portraitPath}}" mode="aspectFill"></image>
                <text wx:else class="{{survivor.portraitFallbackClass}}">{{survivor.portraitFallbackText}}</text>
              </view>
              <view class="survivor-identity-main">
                <text class="survivor-display-name">{{survivor.name}}</text>
                <view class="survivor-tag-row">
                  <text class="{{survivor.rarityBadgeClass}}">{{survivor.rarity}}</text>
                  <text class="survivor-tag survivor-role-tag">{{survivor.role}}</text>
                </view>
              </view>
              <text class="{{survivor.stateTagClass}}">{{survivor.stateTag}}</text>
            </view>
            <view wx:if="{{survivor.traitLabel}}" class="trait-callout trait-callout--compact">
              <text class="trait-kicker">特质</text>
              <text class="trait-value">{{survivor.traitLabel}}</text>
            </view>
            <view class="state-panel state-panel--compact">
              <view class="state-row">
                <text class="state-label">疲劳</text>
                <text class="{{survivor.fatigueClass}}">{{survivor.fatigue}}</text>
              </view>
              <view class="state-row">
                <text class="state-label">健康</text>
                <text class="{{survivor.healthClass}}">{{survivor.health}}</text>
              </view>
            </view>
            <text wx:if="{{survivor.statusNote}}" class="survivor-note survivor-note--danger">{{survivor.statusNote}}</text>
          </view>
        </view>
      </view>
    </block>
    <view wx:else class="card">
      <text class="muted">暂无幸存者数据，请先前往招募页面</text>
    </view>
  </view>

  <view wx:if="{{selectedSurvivor}}" class="section">
    <text class="section-title">派遣确认</text>
    <view class="{{selectedSurvivor.selectedPanelClass}}">
      <view class="survivor-identity-row survivor-identity-row--featured">
        <view class="{{selectedSurvivor.portraitFrameClass}} survivor-portrait--featured">
          <image wx:if="{{selectedSurvivor.hasPortrait}}" class="survivor-portrait-image" src="{{selectedSurvivor.portraitPath}}" mode="aspectFill"></image>
          <text wx:else class="{{selectedSurvivor.portraitFallbackClass}}">{{selectedSurvivor.portraitFallbackText}}</text>
        </view>
        <view class="survivor-identity-main">
          <text class="survivor-display-name survivor-display-name--featured">{{selectedSurvivor.name}}</text>
          <view class="survivor-tag-row">
            <text class="{{selectedSurvivor.rarityBadgeClass}}">{{selectedSurvivor.rarity}}</text>
            <text class="survivor-tag survivor-role-tag">{{selectedSurvivor.role}}</text>
          </view>
        </view>
        <text class="{{selectedSurvivor.stateTagClass}}">{{selectedSurvivor.stateTag}}</text>
      </view>
      <view wx:if="{{selectedSurvivor.traitLabel}}" class="trait-callout">
        <text class="trait-kicker">特质</text>
        <text class="trait-value">{{selectedSurvivor.traitLabel}}</text>
      </view>
      <view class="{{selectedSurvivor.riskHintClass}}">
        <text class="risk-hint-label">派遣判断</text>
        <text class="risk-hint-text">{{selectedSurvivor.riskHintText}}</text>
      </view>
      <view class="flavor-panel">
        <view wx:if="{{selectedSurvivor.workStyleLine}}" class="flavor-row">
          <text class="flavor-label">作风</text>
          <text class="flavor-text">{{selectedSurvivor.workStyleLine}}</text>
        </view>
        <view wx:if="{{selectedSurvivor.archiveLine}}" class="flavor-row">
          <text class="flavor-label">档案</text>
          <text class="flavor-text">{{selectedSurvivor.archiveLine}}</text>
        </view>
        <text wx:if="{{selectedSurvivor.injuredTag}}" class="survivor-note survivor-note--danger">伤情：{{selectedSurvivor.injuredTag}}</text>
        <text wx:if="{{selectedSurvivor.statusNote}}" class="survivor-note survivor-note--danger">{{selectedSurvivor.statusNote}}</text>
      </view>
      <view class="state-panel">
        <view class="state-row">
          <text class="state-label">疲劳</text>
          <text class="{{selectedSurvivor.fatigueClass}}">{{selectedSurvivor.fatigue}}</text>
        </view>
        <view class="state-row">
          <text class="state-label">健康</text>
          <text class="{{selectedSurvivor.healthClass}}">{{selectedSurvivor.health}}</text>
        </view>
      </view>
      <view class="duty-button-list">
        <text class="dispatch-label">派遣选项</text>
        <text class="dispatch-helper">外出搜集和夜间守卫为高风险任务，会更明显地增加疲劳，也可能带来伤情。</text>
        <button
          class="dispatch-card dispatch-card--rest"
          hover-class="dispatch-card--active"
          bindtap="restSurvivor"
          loading="{{assigning}}"
          disabled="{{assigning || actionBlocked || selectedSurvivor.unavailable}}"
        >
          <text class="dispatch-card-kicker">恢复</text>
          <text class="dispatch-card-title">{{actionBlocked ? "本轮行动已结束" : (selectedSurvivor.unavailable ? "不可休整" : "休整")}}</text>
          <text class="dispatch-card-helper">暂停外派，优先恢复成员状态。</text>
        </button>
        <button
          wx:for="{{dutyTypes}}"
          wx:for-item="duty"
          wx:key="type"
          class="{{duty.dispatchCardClass}}"
          hover-class="dispatch-card--active"
          data-duty-type="{{duty.type}}"
          bindtap="assignDuty"
          loading="{{assigning}}"
          disabled="{{assigning || actionBlocked || selectedSurvivor.unavailable}}"
        >
          <view class="dispatch-card-content">
            <view wx:if="{{duty.hasIcon}}" class="dispatch-card-icon-wrap">
              <image
                class="dispatch-card-icon"
                src="{{duty.iconPath}}"
                mode="aspectFit"
                data-duty-type="{{duty.type}}"
                binderror="handleDutyIconError"
              ></image>
            </view>
            <view class="dispatch-card-text">
              <text class="dispatch-card-kicker">{{duty.riskLabel || "普通"}}</text>
              <text class="dispatch-card-title">{{actionBlocked ? "本轮行动已结束" : (selectedSurvivor.unavailable ? "不可派遣" : duty.label)}}</text>
              <text class="dispatch-card-helper">{{duty.helperText}}</text>
            </view>
          </view>
        </button>
        <view wx:if="{{actionBlocked}}" class="message-card">
          <text class="muted">{{actionBlockMessage}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{dutyResult}}" class="section">
    <text class="section-title">值勤结果</text>
    <view class="card result-card {{dutyResult.resultCardClass}}">
      <view class="duty-result-head">
        <view class="duty-result-main">
          <view class="{{dutyResult.portraitFrameClass}} survivor-portrait--compact">
            <image wx:if="{{dutyResult.hasPortrait}}" class="survivor-portrait-image" src="{{dutyResult.portraitPath}}" mode="aspectFill"></image>
            <text wx:else class="{{dutyResult.portraitFallbackClass}}">{{dutyResult.portraitFallbackText}}</text>
          </view>
          <view class="duty-result-copy">
            <text class="result-kicker">结算报告</text>
            <text class="result-title">{{dutyResult.resultTitle}}</text>
            <view class="result-meta-row">
              <text class="result-survivor-name">{{dutyResult.survivorName}}</text>
              <text class="{{dutyResult.survivorRarityBadgeClass}}">{{dutyResult.survivorRarity}}</text>
              <text class="result-meta-chip">{{dutyResult.survivorRole}}</text>
            </view>
          </view>
        </view>
        <view class="result-status-stack">
          <text class="{{dutyResult.settlementBadgeClass}}">{{dutyResult.settlementLabel}}</text>
          <text class="{{dutyResult.stateTagClass}}">{{dutyResult.stateTag}}</text>
        </view>
      </view>
      <text class="result-copy">{{dutyResult.resultText}}</text>
      <view wx:if="{{dutyResult.hasConsequence}}" class="{{dutyResult.consequenceClass}}">
        <text class="result-alert-title">{{dutyResult.consequenceTitle}}</text>
        <text class="result-alert-copy">{{dutyResult.consequenceMessage}}</text>
        <text class="result-alert-detail">{{dutyResult.consequenceDetail}}</text>
      </view>
      <view class="result-feedback-panel result-feedback-panel--compact">
        <view class="feedback-block">
          <text class="feedback-title">资源变化</text>
          <view wx:if="{{dutyResult.hasResourceDeltas}}" class="delta-grid">
            <view wx:for="{{dutyResult.resourceDeltaRows}}" wx:key="label" class="{{item.cardClass}}">
              <text class="delta-label">{{item.label}}</text>
              <text class="{{item.valueClass}}">{{item.valueText}}</text>
            </view>
          </view>
          <text wx:else class="delta-empty">资源未变化</text>
        </view>
        <view wx:if="{{dutyResult.hasStateDeltas}}" class="feedback-block">
          <text class="feedback-title">幸存者状态</text>
          <view class="delta-grid">
            <view wx:for="{{dutyResult.stateDeltaRows}}" wx:key="label" class="{{item.cardClass}}">
              <text class="delta-label">{{item.label}}</text>
              <text class="{{item.valueClass}}">{{item.valueText}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="next-step-panel">
        <text class="next-step-label">下一步建议</text>
        <text class="next-step-text">{{dutyResult.nextStepHint}}</text>
      </view>
      <view wx:if="{{dutyResult.hasDayTransition}}" class="day-transition-card">
        <view class="day-transition-head">
          <text class="day-transition-kicker">今日最后一次行动</text>
          <text class="day-transition-title">{{dutyResult.dayTransitionMessage}}</text>
        </view>
        <view class="day-transition-grid">
          <view wx:for="{{dutyResult.dayTransitionRows}}" wx:key="label" class="day-transition-row">
            <text class="day-transition-label">{{item.label}}</text>
            <text class="day-transition-value">{{item.value}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{dutyResult.traitLabel}}" class="trait-callout trait-callout--compact">
        <text class="trait-kicker">特质</text>
        <text class="trait-value">{{dutyResult.traitLabel}}</text>
      </view>
      <view class="flavor-panel">
        <view wx:if="{{dutyResult.workStyleLine}}" class="flavor-row">
          <text class="flavor-label">作风</text>
          <text class="flavor-text">{{dutyResult.workStyleLine}}</text>
        </view>
        <view wx:if="{{dutyResult.archiveLine}}" class="flavor-row">
          <text class="flavor-label">档案</text>
          <text class="flavor-text">{{dutyResult.archiveLine}}</text>
        </view>
        <text wx:if="{{dutyResult.injuredTag}}" class="survivor-note survivor-note--danger">伤情：{{dutyResult.injuredTag}}</text>
      </view>
      <view class="state-panel">
        <view class="state-row">
          <text class="state-label">疲劳</text>
          <text class="{{dutyResult.fatigueClass}}">{{dutyResult.fatigue}}</text>
        </view>
        <view class="state-row">
          <text class="state-label">健康</text>
          <text class="{{dutyResult.healthClass}}">{{dutyResult.health}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{offerHintVisible}}" class="offer-hint-card">
      <view>
        <text class="offer-hint-kicker">补给室来讯</text>
        <text class="offer-hint-copy">{{offerHintText}}</text>
        <text class="offer-hint-source">压力来源：{{offerHintTriggerLabel}}</text>
      </view>
      <button class="offer-hint-button" hover-class="offer-hint-button--active" bindtap="goHomeForOffer">去首页处理</button>
    </view>
  </view>

  <view class="section">
    <text class="section-title">快速前往</text>
    <view class="nav-list">
      <navigator class="nav-card" hover-class="nav-card--active" url="/pages/home/home" open-type="switchTab">返回首页</navigator>
      <navigator class="nav-card" hover-class="nav-card--active" url="/pages/gacha/gacha" open-type="switchTab">幸存者招募</navigator>
      <navigator class="nav-card" hover-class="nav-card--active" url="/pages/logs/logs" open-type="switchTab">查看日志</navigator>
    </view>
  </view>
</view>
