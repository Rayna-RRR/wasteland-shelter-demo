.page-resource-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.page-resource-grid + .page-resource-grid {
  margin-top: 16rpx;
}

.page-resource-grid .resource-item {
  width: auto;
  min-width: 0;
}

.page-resource-grid .resource-item--wide {
  grid-column: 1 / -1;
}

.survivor-card--hover {
  background: rgba(33, 33, 33, 0.88);
  transform: translateY(-2rpx);
}

.survivor-card {
  margin-bottom: 18rpx;
}

.selected-ribbon {
  display: inline-block;
  box-sizing: border-box;
  min-height: 36rpx;
  margin-bottom: 12rpx;
  padding: 4rpx 12rpx;
  border: 1rpx solid rgba(57, 255, 20, 0.42);
  border-radius: 8rpx;
  color: var(--radiation-green);
  background: rgba(57, 255, 20, 0.12);
  font-size: 21rpx;
  font-weight: 700;
  line-height: 28rpx;
}

.survivor-note {
  display: block;
  margin-top: 12rpx;
  color: rgba(211, 211, 211, 0.82);
  font-size: 25rpx;
  line-height: 1.5;
}

.survivor-note--danger {
  color: #ff8a80;
}

.flavor-panel {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(193, 154, 107, 0.20);
}

.flavor-panel--compact {
  margin-top: 14rpx;
  padding-top: 12rpx;
}

.flavor-row {
  display: flex;
  gap: 14rpx;
  margin-top: 10rpx;
}

.flavor-row:first-child {
  margin-top: 0;
}

.flavor-label {
  flex: 0 0 72rpx;
  color: var(--desert-yellow);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.55;
}

.flavor-text {
  flex: 1;
  min-width: 0;
  color: rgba(211, 211, 211, 0.84);
  font-size: 25rpx;
  line-height: 1.55;
}

.risk-hint {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.30);
  border-left: 6rpx solid var(--desert-yellow);
  border-radius: 8rpx;
  background:
    linear-gradient(90deg, rgba(193, 154, 107, 0.12), transparent),
    rgba(0, 0, 0, 0.22);
}

.risk-hint--normal {
  border-left-color: var(--radiation-green);
}

.risk-hint--warning {
  border-color: rgba(255, 87, 34, 0.38);
  border-left-color: var(--hazard-orange);
  background:
    linear-gradient(90deg, rgba(255, 87, 34, 0.13), transparent),
    rgba(0, 0, 0, 0.22);
}

.risk-hint--danger {
  border-color: rgba(255, 106, 106, 0.46);
  border-left-color: #ff6a6a;
  background:
    linear-gradient(90deg, rgba(139, 58, 58, 0.28), transparent),
    rgba(0, 0, 0, 0.24);
}

.risk-hint-label {
  display: block;
  color: var(--desert-yellow);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
}

.risk-hint-text {
  display: block;
  margin-top: 8rpx;
  color: rgba(211, 211, 211, 0.88);
  font-size: 25rpx;
  line-height: 1.45;
}

.duty-button-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.dispatch-label {
  display: block;
  grid-column: 1 / -1;
  color: var(--desert-yellow);
  font-size: 24rpx;
  font-weight: 700;
}

.dispatch-helper {
  display: block;
  grid-column: 1 / -1;
  margin-top: -2rpx;
  color: rgba(211, 211, 211, 0.74);
  font-size: 23rpx;
  line-height: 1.45;
}

.dispatch-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  min-height: 142rpx;
  margin: 0;
  padding: 16rpx 18rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.34);
  border-radius: 8rpx;
  background:
    linear-gradient(135deg, rgba(193, 154, 107, 0.12), rgba(0, 0, 0, 0.08)),
    rgba(18, 18, 18, 0.86);
  color: var(--base-text);
  line-height: 1.35;
  text-align: left;
}

.dispatch-card--risk {
  border-color: rgba(255, 87, 34, 0.38);
  background:
    linear-gradient(135deg, rgba(255, 87, 34, 0.14), rgba(0, 0, 0, 0.08)),
    rgba(18, 18, 18, 0.88);
}

.dispatch-card--rest {
  border-color: rgba(57, 255, 20, 0.34);
  background:
    linear-gradient(135deg, rgba(57, 255, 20, 0.11), rgba(0, 0, 0, 0.08)),
    rgba(14, 18, 14, 0.88);
}

.dispatch-card-kicker {
  display: block;
  color: var(--muted-text);
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.3;
}

.dispatch-card--risk .dispatch-card-kicker {
  color: var(--hazard-orange);
}

.dispatch-card--rest .dispatch-card-kicker {
  color: var(--radiation-green);
}

.dispatch-card-title {
  display: block;
  margin-top: 8rpx;
  color: var(--base-text);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
}

.dispatch-card-helper {
  display: block;
  margin-top: 8rpx;
  color: rgba(211, 211, 211, 0.72);
  font-size: 22rpx;
  line-height: 1.35;
}

.dispatch-card--active {
  opacity: 0.88;
  transform: translateY(2rpx);
}

.dispatch-card[disabled] {
  border-color: rgba(211, 211, 211, 0.16);
  background: #343434;
  color: rgba(211, 211, 211, 0.58);
}

.dispatch-card[disabled] .dispatch-card-kicker,
.dispatch-card[disabled] .dispatch-card-title,
.dispatch-card[disabled] .dispatch-card-helper {
  color: rgba(211, 211, 211, 0.54);
}

.duty-button-list > .message-card {
  grid-column: 1 / -1;
  margin-top: 4rpx;
}

.duty-result-card {
  position: relative;
  overflow: hidden;
}

.duty-result-card--enter-0 {
  animation: duty-result-enter-a 320ms ease-out both;
  will-change: opacity, transform;
}

.duty-result-card--enter-1 {
  animation: duty-result-enter-b 320ms ease-out both;
  will-change: opacity, transform;
}

.duty-result-card--enter-0 .delta-card--gain {
  animation: duty-delta-gain-a 620ms ease-out both;
}

.duty-result-card--enter-1 .delta-card--gain {
  animation: duty-delta-gain-b 620ms ease-out both;
}

.duty-result-card--enter-0 .delta-card--loss {
  animation: duty-delta-loss-a 620ms ease-out both;
}

.duty-result-card--enter-1 .delta-card--loss {
  animation: duty-delta-loss-b 620ms ease-out both;
}

.duty-result-card--enter-0 .delta-card--neutral {
  animation: duty-delta-neutral-a 520ms ease-out both;
}

.duty-result-card--enter-1 .delta-card--neutral {
  animation: duty-delta-neutral-b 520ms ease-out both;
}

.duty-result-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.duty-result-main {
  display: flex;
  flex: 1;
  min-width: 0;
  gap: 16rpx;
}

.duty-result-copy {
  flex: 1;
  min-width: 0;
}

.result-status-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.result-kicker {
  display: block;
  color: var(--desert-yellow);
  font-size: 23rpx;
  font-weight: 700;
}

.result-title {
  display: block;
  margin-top: 6rpx;
  color: var(--base-text);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.result-signal-badge {
  box-sizing: border-box;
  min-height: 40rpx;
  padding: 5rpx 14rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.36);
  border-radius: 8rpx;
  color: var(--desert-yellow);
  background: rgba(193, 154, 107, 0.10);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 30rpx;
  white-space: nowrap;
}

.result-copy {
  display: block;
  margin-top: 18rpx;
  color: rgba(211, 211, 211, 0.9);
  font-size: 27rpx;
  line-height: 1.55;
}

.result-alert {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(255, 87, 34, 0.36);
  border-left: 6rpx solid var(--hazard-orange);
  border-radius: 8rpx;
  background: rgba(139, 58, 58, 0.18);
}

.result-alert--danger {
  border-color: rgba(255, 106, 106, 0.48);
  border-left-color: #ff6a6a;
  background: rgba(139, 58, 58, 0.24);
}

.result-alert--warning {
  border-color: rgba(255, 87, 34, 0.40);
  border-left-color: var(--hazard-orange);
}

.result-alert-title {
  display: block;
  color: var(--hazard-orange);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
}

.result-alert--danger .result-alert-title {
  color: #ff8a80;
}

.result-alert-copy,
.result-alert-detail {
  display: block;
  margin-top: 8rpx;
  color: rgba(211, 211, 211, 0.86);
  font-size: 25rpx;
  line-height: 1.45;
}

.result-alert-detail {
  color: var(--desert-yellow);
  font-weight: 700;
}

.result-feedback-panel {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.26);
  border-radius: 8rpx;
  background:
    linear-gradient(135deg, rgba(193, 154, 107, 0.08), transparent 54%),
    rgba(0, 0, 0, 0.22);
}

.feedback-block + .feedback-block {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(193, 154, 107, 0.16);
}

.feedback-title {
  display: block;
  color: var(--desert-yellow);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.delta-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.delta-card {
  flex: 1 1 28%;
  box-sizing: border-box;
  min-width: 150rpx;
  min-height: 92rpx;
  padding: 13rpx 14rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.22);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.20);
}

.delta-card--gain {
  border-color: rgba(57, 255, 20, 0.34);
  background: rgba(57, 255, 20, 0.08);
}

.delta-card--loss {
  border-color: rgba(255, 87, 34, 0.36);
  background: rgba(139, 58, 58, 0.16);
}

.delta-card--neutral {
  border-color: rgba(155, 146, 134, 0.28);
  background: rgba(95, 90, 82, 0.10);
}

.delta-label {
  display: block;
  color: var(--muted-text);
  font-size: 21rpx;
  line-height: 1.3;
}

.delta-value {
  display: block;
  margin-top: 7rpx;
  color: var(--base-text);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
}

.delta-value--gain {
  color: var(--radiation-green);
  text-shadow: 0 0 12rpx rgba(57, 255, 20, 0.22);
}

.delta-value--loss {
  color: var(--hazard-orange);
}

.delta-value--neutral {
  color: rgba(211, 211, 211, 0.78);
}

.delta-empty {
  display: block;
  margin-top: 12rpx;
  color: rgba(155, 146, 134, 0.78);
  font-size: 24rpx;
  line-height: 1.45;
}

.day-transition-card {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.32);
  border-left: 6rpx solid var(--desert-yellow);
  border-radius: 8rpx;
  background:
    linear-gradient(135deg, rgba(193, 154, 107, 0.12), transparent 54%),
    rgba(0, 0, 0, 0.22);
}

.day-transition-kicker {
  display: block;
  color: var(--desert-yellow);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
}

.day-transition-title {
  display: block;
  margin-top: 6rpx;
  color: var(--base-text);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.day-transition-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10rpx;
  margin-top: 14rpx;
}

.day-transition-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
  padding: 12rpx 14rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.20);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.18);
}

.day-transition-label {
  flex: 0 0 120rpx;
  color: var(--muted-text);
  font-size: 22rpx;
  line-height: 1.35;
}

.day-transition-value {
  flex: 1;
  min-width: 0;
  color: var(--desert-yellow);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  text-align: right;
}

.offer-hint-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 87, 34, 0.38);
  border-left: 6rpx solid var(--hazard-orange);
  border-radius: 8rpx;
  background:
    linear-gradient(90deg, rgba(139, 58, 58, 0.22), transparent),
    rgba(16, 14, 13, 0.92);
}

.offer-hint-kicker {
  display: block;
  color: var(--hazard-orange);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.35;
}

.offer-hint-copy {
  display: block;
  margin-top: 6rpx;
  color: rgba(211, 211, 211, 0.86);
  font-size: 25rpx;
  line-height: 1.45;
}

.offer-hint-source {
  display: block;
  margin-top: 6rpx;
  color: var(--desert-yellow);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
}

.offer-hint-button {
  flex: 0 0 176rpx;
  min-height: 66rpx;
  margin: 0;
  padding: 0 12rpx;
  border: 1rpx solid rgba(57, 255, 20, 0.34);
  border-radius: 8rpx;
  background: rgba(57, 255, 20, 0.10);
  color: var(--radiation-green);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 66rpx;
}

.offer-hint-button--active {
  opacity: 0.88;
  transform: translateY(2rpx);
}

@keyframes duty-result-enter-a {
  0% {
    opacity: 0;
    transform: translateY(16rpx) scale(0.99);
  }

  72% {
    opacity: 1;
    transform: translateY(-1rpx) scale(1.004);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes duty-result-enter-b {
  0% {
    opacity: 0;
    transform: translateY(16rpx) scale(0.99);
  }

  72% {
    opacity: 1;
    transform: translateY(-1rpx) scale(1.004);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes duty-delta-gain-a {
  0% {
    box-shadow: 0 0 0 rgba(57, 255, 20, 0);
  }

  42% {
    box-shadow: 0 0 22rpx rgba(57, 255, 20, 0.24);
  }

  100% {
    box-shadow: none;
  }
}

@keyframes duty-delta-gain-b {
  0% {
    box-shadow: 0 0 0 rgba(57, 255, 20, 0);
  }

  42% {
    box-shadow: 0 0 22rpx rgba(57, 255, 20, 0.24);
  }

  100% {
    box-shadow: none;
  }
}

@keyframes duty-delta-loss-a {
  0% {
    box-shadow: 0 0 0 rgba(255, 87, 34, 0);
  }

  42% {
    box-shadow: 0 0 22rpx rgba(255, 87, 34, 0.24);
  }

  100% {
    box-shadow: none;
  }
}

@keyframes duty-delta-loss-b {
  0% {
    box-shadow: 0 0 0 rgba(255, 87, 34, 0);
  }

  42% {
    box-shadow: 0 0 22rpx rgba(255, 87, 34, 0.24);
  }

  100% {
    box-shadow: none;
  }
}

@keyframes duty-delta-neutral-a {
  0% {
    box-shadow: 0 0 0 rgba(193, 154, 107, 0);
  }

  42% {
    box-shadow: 0 0 18rpx rgba(193, 154, 107, 0.16);
  }

  100% {
    box-shadow: none;
  }
}

@keyframes duty-delta-neutral-b {
  0% {
    box-shadow: 0 0 0 rgba(193, 154, 107, 0);
  }

  42% {
    box-shadow: 0 0 18rpx rgba(193, 154, 107, 0.16);
  }

  100% {
    box-shadow: none;
  }
}
