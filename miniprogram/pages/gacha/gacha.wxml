<view class="page">
  <view class="header">
    <text class="title">幸存者招募</text>
    <text class="subtitle">招募舱待命</text>
  </view>

  <view class="section">
    <text class="section-title">当前资源</text>
    <view class="resource-grid page-resource-grid">
      <view class="resource-item">
        <text class="resource-label">食物</text>
        <text class="resource-value">{{resources.food}}</text>
      </view>
      <view class="resource-item">
        <text class="resource-label">电力</text>
        <text class="resource-value">{{resources.power}}</text>
      </view>
      <view class="resource-item">
        <text class="resource-label">材料</text>
        <text class="resource-value">{{resources.materials}}</text>
      </view>
      <view class="resource-item">
        <text class="resource-label">招募券</text>
        <text class="resource-value">{{resources.premium_currency}}</text>
      </view>
    </view>
    <view wx:if="{{loadingResources}}" class="message-card">
      <text class="muted">资源刷新中...</text>
    </view>
    <view wx:if="{{hasRunState}}" class="resource-grid page-resource-grid run-state-grid">
      <view class="resource-item">
        <text class="resource-label">当前天数</text>
        <text class="resource-value">{{runState.current_day}} / {{runState.total_days}}</text>
      </view>
      <view class="resource-item">
        <text class="resource-label">今日行动</text>
        <text class="resource-value">{{runState.actions_left}} / {{runState.actions_per_day}}</text>
      </view>
      <view class="resource-item resource-item--wide">
        <text class="resource-label">威胁倒计时</text>
        <text class="resource-value">{{runState.threat_days_left}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="recruit-console">
      <view wx:if="{{isPullAnimating}}" class="recruit-signal-overlay">
        <view class="signal-band signal-band--one"></view>
        <view class="signal-band signal-band--two"></view>
        <view class="signal-band signal-band--three"></view>
      </view>
      <view class="console-topline">
        <text class="console-kicker">招募控制台</text>
        <text class="console-status">{{revealStatusText}}</text>
      </view>
      <button class="action-button recruit-switch" hover-class="action-button--active" bindtap="pullSurvivor" loading="{{pulling}}" disabled="{{pulling || actionBlocked}}">{{actionBlocked ? "本轮行动已结束" : "进行一次招募"}}</button>
      <view wx:if="{{actionBlocked}}" class="message-card">
        <text class="muted">{{actionBlockMessage}}</text>
      </view>
      <view wx:if="{{isPullAnimating}}" class="reveal-panel">
        <text class="reveal-title">信号解码中</text>
        <text class="reveal-copy">招募舱正在校准身份信标...</text>
        <view class="reveal-bars">
          <view class="reveal-bar"></view>
          <view class="reveal-bar reveal-bar--delay"></view>
          <view class="reveal-bar reveal-bar--slow"></view>
        </view>
      </view>
    </view>
    <view wx:if="{{errorMessage}}" class="message-card">
      <text class="muted">{{errorMessage}}</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">招募结果</text>
    <view wx:if="{{isPullAnimating}}" class="card result-placeholder">
      <text class="muted">弱信号传输中，请等待招募舱回传档案...</text>
    </view>
    <view wx:elif="{{showResultCard && survivor}}" class="{{survivor.resultCardClass}}">
      <view class="recruit-card-head">
        <view class="{{survivor.portraitFrameClass}} survivor-portrait--recruit">
          <image wx:if="{{survivor.hasPortrait}}" class="survivor-portrait-image" src="{{survivor.portraitPath}}" mode="aspectFill"></image>
          <text wx:else class="{{survivor.portraitFallbackClass}}">{{survivor.portraitFallbackText}}</text>
        </view>
        <view class="recruit-identity">
          <text class="result-signal-title">{{survivor.resultSignalText}}</text>
          <text class="recruit-name">{{survivor.name}}</text>
          <view class="recruit-meta-row">
            <text class="{{survivor.rarityBadgeClass}}">{{survivor.rarity}}</text>
            <text class="role-pill">{{survivor.role}}</text>
          </view>
        </view>
        <view class="recruit-state-stack">
          <text wx:if="{{survivor.currentStateTag}}" class="result-state-tag">{{survivor.currentStateTag}}</text>
          <text wx:if="{{survivor.duplicate}}" class="duplicate-badge">重复信号</text>
        </view>
      </view>

      <view wx:if="{{survivor.traitLabel}}" class="trait-callout">
        <text class="trait-kicker">特质</text>
        <text class="trait-value">{{survivor.traitLabel}}</text>
      </view>

      <view wx:if="{{survivor.duplicate}}" class="duplicate-compensation-panel">
        <view>
          <text class="compensation-kicker">重复角色补偿</text>
          <text class="compensation-copy">该幸存者已在队伍中，信号转化为可见材料收益。</text>
        </view>
        <view class="compensation-value-block">
          <text class="compensation-value">{{survivor.compensationAmountText}}</text>
          <text class="compensation-label">{{survivor.compensationResourceText}}</text>
        </view>
      </view>

      <view class="archive-lines character-lines">
        <text wx:if="{{survivor.duplicate}}" class="archive-line archive-line--warning">结果：重复成员</text>
        <text wx:if="{{survivor.compensationText}}" class="archive-line archive-line--warning">补偿：{{survivor.compensationText}}</text>
        <text wx:if="{{survivor.injuredTag}}" class="archive-line archive-line--danger">伤情：{{survivor.injuredTag}}</text>
        <view wx:if="{{survivor.workStyleLine}}" class="flavor-row">
          <text class="flavor-label">作风</text>
          <text class="flavor-text">{{survivor.workStyleLine}}</text>
        </view>
        <view wx:if="{{survivor.archiveLine}}" class="flavor-row">
          <text class="flavor-label">档案</text>
          <text class="flavor-text">{{survivor.archiveLine}}</text>
        </view>
        <view wx:if="{{survivor.gachaIntroLine}}" class="flavor-row flavor-row--signal">
          <text class="flavor-label">入队</text>
          <text class="flavor-text">{{survivor.gachaIntroLine}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="card">
      <text class="muted">暂无招募结果</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">快速前往</text>
    <view class="nav-list">
      <navigator class="nav-card" hover-class="nav-card--active" url="/pages/home/home" open-type="switchTab">返回首页</navigator>
      <navigator class="nav-card" hover-class="nav-card--active" url="/pages/duty/duty" open-type="switchTab">安排值勤</navigator>
      <navigator class="nav-card" hover-class="nav-card--active" url="/pages/logs/logs" open-type="switchTab">查看日志</navigator>
    </view>
  </view>
</view>
