<view class="page home-page">
  <view class="home-texture"></view>

  <block wx:if="{{checkingInit}}">
    <view class="header home-header">
      <text class="header-kicker">避难所控制台</text>
      <text class="title">信号校验中</text>
      <text class="subtitle">正在读取避难所登记状态...</text>
    </view>
    <view class="section">
      <view class="message-card">
        <text class="muted">请稍候，控制台正在接入本地档案。</text>
      </view>
    </view>
  </block>

  <block wx:elif="{{!initialized}}">
    <view class="header home-header">
      <text class="header-kicker">首次接入</text>
      <text class="title">废土避难所</text>
      <text class="subtitle">尘暴正在逼近，先登记你的避难所。</text>
    </view>

    <view class="section onboarding-section">
      <view class="onboarding-card">
        <text class="onboarding-kicker">开局档案</text>
        <text class="onboarding-title">接管一座还在喘息的地下避难所</text>
        <text class="onboarding-copy">{{initIntroText}}</text>

        <view class="init-field">
          <text class="init-label">避难所代号</text>
          <input class="init-input" placeholder="例如：灰井 07" placeholder-class="init-placeholder" data-field="shelter_code" value="{{initForm.shelter_code}}" bindinput="updateInitField" />
        </view>

        <view class="init-field">
          <text class="init-label">指挥官</text>
          <input class="init-input" placeholder="输入你的称呼" placeholder-class="init-placeholder" data-field="commander_name" value="{{initForm.commander_name}}" bindinput="updateInitField" />
        </view>

        <view class="init-field">
          <text class="init-label">当前难度</text>
          <picker mode="selector" range="{{difficultyOptions}}" value="{{difficultyIndex}}" bindchange="changeDifficulty">
            <view class="difficulty-picker">
              <text>{{initForm.difficulty}}</text>
              <text class="difficulty-arrow">切换</text>
            </view>
          </picker>
          <text class="difficulty-note">{{difficultyNote}}</text>
        </view>

        <view wx:if="{{initErrorMessage}}" class="message-card init-error-card">
          <text class="muted">{{initErrorMessage}}</text>
        </view>

        <button class="action-button control-button" hover-class="action-button--active" bindtap="submitInit" loading="{{initSubmitting}}" disabled="{{initSubmitting}}">接入避难所控制台</button>
      </view>
    </view>
  </block>

  <block wx:else>
  <view class="header home-header">
    <text class="header-kicker">避难所控制台</text>
    <text class="title">废土避难所</text>
    <text class="subtitle">{{homeSubtitle}}</text>
  </view>

  <view wx:if="{{hasPendingEvent || eventResultMessage || eventErrorMessage}}" class="section event-section">
    <view class="section-heading">
      <view>
        <text class="section-kicker">今日事件</text>
        <text class="section-title">待处理状况</text>
      </view>
      <text wx:if="{{hasPendingEvent}}" class="resource-status resource-status--warning">需选择</text>
    </view>
    <view wx:if="{{hasPendingEvent}}" class="event-card">
      <view class="event-topline">
        <text class="event-day-label">第 {{pendingEvent.day}} 天事件</text>
        <text class="event-priority-label">先处理</text>
      </view>
      <text class="event-title">{{pendingEvent.title}}</text>
      <text class="event-copy">{{pendingEvent.description}}</text>
      <view class="event-choice-list">
        <button
          wx:for="{{pendingEvent.choices}}"
          wx:key="id"
          class="event-choice-button"
          hover-class="event-choice-button--active"
          data-choice-id="{{item.id}}"
          bindtap="resolvePendingEvent"
          loading="{{eventResolving}}"
          disabled="{{eventResolving}}"
        >
          <text class="event-choice-label">{{item.label}}</text>
          <text class="event-choice-desc">{{item.description}}</text>
        </button>
      </view>
    </view>
    <view wx:if="{{eventErrorMessage}}" class="message-card">
      <text class="muted">{{eventErrorMessage}}</text>
    </view>
    <view wx:if="{{eventResultMessage}}" class="message-card">
      <text class="muted">{{eventResultMessage}}</text>
    </view>
  </view>

  <view wx:if="{{hasRunState}}" class="section run-overview-section">
    <view class="section-heading">
      <view>
        <text class="section-kicker">当前局</text>
        <text class="section-title">运行概览</text>
      </view>
      <text class="{{runStatusClass}}">{{runStatusLabel}}</text>
    </view>
    <view class="{{runOverviewClass}}">
      <view class="run-overview-main">
        <view>
          <text class="run-overview-kicker">{{runOverviewLead}}</text>
          <text class="run-overview-title">{{runOverviewTitle}}</text>
        </view>
        <text class="{{runStatusClass}}">{{runStatusLabel}}</text>
      </view>
      <view class="run-overview-grid">
        <view wx:for="{{runOverviewItems}}" wx:key="label" class="{{item.itemClass}}">
          <text class="run-overview-label">{{item.label}}</text>
          <text class="run-overview-value">{{item.value}}</text>
          <text class="run-overview-helper">{{item.helper}}</text>
        </view>
      </view>
      <text class="run-overview-note">{{runOverviewNote}}</text>
    </view>
    <view wx:if="{{runResultMessage}}" class="message-card">
      <text class="muted">{{runResultMessage}}</text>
    </view>
    <view wx:if="{{hasSettlementSummary}}" class="message-card settlement-message-card">
      <text class="settlement-title">{{settlementSummary.title}}</text>
      <text class="muted">{{settlementSummary.resultText}}</text>
      <text class="muted">{{settlementSummary.paidText}}</text>
      <text class="muted">{{settlementSummary.shortfallText}}</text>
      <text class="muted">{{settlementSummary.teamPenaltyText}}</text>
    </view>
  </view>

  <view class="section commander-section">
    <view class="section-heading">
      <view>
        <text class="section-kicker">避难所档案</text>
        <text class="section-title">当前指挥</text>
      </view>
    </view>
    <view class="commander-grid">
      <view class="commander-chip">
        <text class="commander-label">避难所代号</text>
        <text class="commander-value">{{initProfile.shelter_code}}</text>
      </view>
      <view class="commander-chip">
        <text class="commander-label">指挥官</text>
        <text class="commander-value">{{initProfile.commander_name}}</text>
      </view>
      <view class="commander-chip commander-chip--wide">
        <text class="commander-label">当前难度</text>
        <text class="commander-value">{{initProfile.difficulty}}</text>
      </view>
    </view>
  </view>

  <view class="section resource-section">
    <view class="section-heading">
      <view>
        <text class="section-kicker">资源监控</text>
        <text class="section-title">当前资源</text>
      </view>
      <text class="{{resourcePanelClass}}">{{resourceStatusText}}</text>
    </view>
    <view wx:if="{{loading}}" class="message-card">
      <text class="muted">资源加载中...</text>
    </view>
    <view wx:elif="{{errorMessage}}" class="message-card">
      <text class="muted">{{errorMessage}}</text>
    </view>
    <view class="resource-grid resource-instrument-grid">
      <view wx:for="{{resourceCards}}" wx:key="key" class="{{item.cardClass}}">
        <view class="instrument-topline">
          <text class="instrument-code">{{item.code}}</text>
          <text class="instrument-status">{{item.statusLabel}}</text>
        </view>
        <text class="resource-label">{{item.label}}</text>
        <text class="resource-value">{{item.value}}</text>
        <view class="resource-meter">
          <view class="{{item.meterClass}}" style="{{item.meterStyle}}"></view>
        </view>
        <text class="resource-threshold">{{item.thresholdText}}</text>
      </view>
    </view>
    <view wx:if="{{resources.power_shortage}}" class="message-card power-shortage-card">
      <text class="muted">电力短缺：避难所已进入低功耗运行。</text>
    </view>
    <button class="action-button control-button" hover-class="action-button--active" bindtap="refreshHome" loading="{{loading}}" disabled="{{loading}}">刷新资源</button>
  </view>

  <view wx:if="{{offerVisible || offerResultMessage || offerErrorMessage}}" class="section offer-section">
    <view class="section-heading">
      <view>
        <text class="section-kicker">事件通讯</text>
        <text class="section-title">补给室来讯</text>
      </view>
    </view>
    <view wx:if="{{offerVisible}}" class="offer-card">
      <view class="offer-topline">
        <text class="offer-kicker">战备补给协议</text>
        <text class="offer-badge">协议：{{offer.urgency_label}}</text>
      </view>
      <text class="offer-title">{{offer.title}}</text>
      <text class="offer-copy">{{offer.subtitle}}</text>
      <view class="offer-signal-grid">
        <view class="offer-signal">
          <text class="offer-signal-label">压力来源</text>
          <text class="offer-signal-value">{{offerTriggerLabel}}</text>
        </view>
        <view class="offer-signal">
          <text class="offer-signal-label">协议费用</text>
          <text class="offer-signal-value">{{offer.price_label}}</text>
        </view>
      </view>
      <text class="offer-reward-title">补给内容</text>
      <view class="offer-reward-grid">
        <view wx:for="{{offerRewardRows}}" wx:key="label" class="offer-reward">
          <text class="offer-reward-label">{{item.label}}</text>
          <text class="offer-reward-value">{{item.value}}</text>
        </view>
      </view>
      <view class="offer-actions">
        <button class="offer-button-secondary" hover-class="offer-button--active" bindtap="closeEmergencyOffer" disabled="{{offerPurchasing}}">暂缓处理</button>
        <button class="offer-button-primary" hover-class="offer-button--active" bindtap="purchaseEmergencyOffer" loading="{{offerPurchasing}}" disabled="{{offerPurchasing}}">启用协议 · {{offer.price_label}}</button>
      </view>
    </view>
    <view wx:if="{{offerErrorMessage}}" class="message-card">
      <text class="muted">{{offerErrorMessage}}</text>
    </view>
    <view wx:if="{{offerResultMessage}}" class="message-card">
      <text class="muted">{{offerResultMessage}}</text>
    </view>
  </view>

  <view wx:if="{{isLocalDev}}" class="section debug-section">
    <text class="section-title">本地调试</text>
    <view class="debug-card">
      <view class="debug-mode-panel">
        <view>
          <text class="debug-mode-title">录屏模式</text>
          <text class="debug-helper">开启后，前两次招募固定为 SSR 周萤（仅本地录屏用）。</text>
          <text wx:if="{{demoModeErrorMessage}}" class="debug-error">{{demoModeErrorMessage}}</text>
        </view>
        <view class="debug-mode-action">
          <text class="debug-mode-state">当前：{{demoModeEnabled ? "开启" : "关闭"}}</text>
          <button class="debug-button debug-mode-button" hover-class="debug-button--active" bindtap="toggleDemoModeDebug" loading="{{demoModeLoading}}" disabled="{{demoModeLoading}}">录屏模式：{{demoModeEnabled ? "关闭" : "开启"}}</button>
        </view>
      </view>
      <text class="debug-helper">仅本地开发可见，用于清空补给协议测试记录并重新触发测试流程。</text>
      <button class="debug-button" hover-class="debug-button--active" bindtap="confirmResetEmergencyOfferDebug" loading="{{debugResetting}}" disabled="{{debugResetting}}">重置补给测试状态</button>
      <text class="debug-helper debug-helper--spaced">仅本地开发可见，用于清空当前局并返回首次接入。</text>
      <button class="debug-button" hover-class="debug-button--active" bindtap="confirmResetInitDebug" loading="{{debugInitResetting}}" disabled="{{debugInitResetting}}">新开局重置</button>
    </view>
  </view>

  <view class="section">
    <text class="section-title">快速前往</text>
    <view class="nav-list">
      <navigator class="nav-card" hover-class="nav-card--active" url="/pages/gacha/gacha" open-type="switchTab">幸存者招募</navigator>
      <navigator class="nav-card" hover-class="nav-card--active" url="/pages/duty/duty" open-type="switchTab">值勤调度</navigator>
      <navigator class="nav-card" hover-class="nav-card--active" url="/pages/logs/logs" open-type="switchTab">行动日志</navigator>
    </view>
  </view>
  </block>
</view>
