.home-page {
  position: relative;
  overflow: hidden;
  padding-top: 34rpx;
}

.home-texture {
  pointer-events: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 100vh;
  z-index: 0;
  opacity: 0.10;
  background-image:
    linear-gradient(115deg, rgba(193, 154, 107, 0.07), transparent 42%, rgba(139, 58, 58, 0.07));
  background-repeat: no-repeat;
}

.home-header,
.section {
  position: relative;
  z-index: 1;
}

.home-header {
  padding: 26rpx 26rpx 24rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.28);
  border-left: 8rpx solid var(--rust-red);
  border-radius: 8rpx;
  background:
    linear-gradient(90deg, rgba(139, 58, 58, 0.24), transparent 58%),
    rgba(17, 16, 15, 0.82);
  box-shadow: 0 20rpx 54rpx rgba(0, 0, 0, 0.34);
}

.header-kicker,
.section-kicker {
  display: block;
  color: var(--muted-text);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.home-header .title {
  margin-top: 8rpx;
  font-size: 52rpx;
}

.section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid rgba(193, 154, 107, 0.24);
}

.section-heading .section-title {
  margin-bottom: 0;
}

.onboarding-card {
  box-sizing: border-box;
  padding: 30rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.34);
  border-left: 8rpx solid var(--rust-red);
  border-radius: 8rpx;
  background:
    linear-gradient(135deg, rgba(139, 58, 58, 0.22), transparent 46%),
    rgba(15, 14, 13, 0.94);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.36);
}

.onboarding-kicker {
  display: block;
  color: var(--desert-yellow);
  font-size: 24rpx;
  font-weight: 700;
}

.onboarding-title {
  display: block;
  margin-top: 10rpx;
  color: var(--base-text);
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.onboarding-copy {
  display: block;
  margin-top: 12rpx;
  color: rgba(211, 211, 211, 0.82);
  font-size: 26rpx;
  line-height: 1.55;
}

.init-field {
  margin-top: 24rpx;
}

.init-label {
  display: block;
  color: var(--desert-yellow);
  font-size: 24rpx;
  font-weight: 700;
}

.init-input,
.difficulty-picker {
  box-sizing: border-box;
  width: 100%;
  min-height: 76rpx;
  margin-top: 12rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.30);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.24);
  color: var(--base-text);
  font-size: 28rpx;
  line-height: 76rpx;
}

.init-placeholder {
  color: rgba(155, 146, 134, 0.72);
}

.difficulty-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.difficulty-arrow {
  color: var(--muted-text);
  font-size: 24rpx;
}

.difficulty-note {
  display: block;
  margin-top: 10rpx;
  color: var(--muted-text);
  font-size: 23rpx;
  line-height: 1.45;
}

.init-error-card {
  margin-top: 22rpx;
}

.commander-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.commander-chip {
  box-sizing: border-box;
  width: calc(50% - 7rpx);
  min-height: 96rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.26);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.22);
}

.commander-chip--wide {
  width: 100%;
}

.commander-label {
  display: block;
  color: var(--muted-text);
  font-size: 22rpx;
}

.commander-value {
  display: block;
  margin-top: 8rpx;
  color: var(--desert-yellow);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.home-survivor-card {
  box-sizing: border-box;
  margin-top: 14rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.30);
  border-left: 6rpx solid var(--desert-yellow);
  border-radius: 8rpx;
  background:
    linear-gradient(135deg, rgba(193, 154, 107, 0.10), transparent 48%),
    rgba(15, 14, 13, 0.90);
}

.home-survivor-card:first-of-type {
  margin-top: 0;
}

.home-survivor-card--ssr {
  border-color: rgba(255, 87, 34, 0.42);
  border-left-color: var(--hazard-orange);
  background:
    linear-gradient(135deg, rgba(255, 87, 34, 0.12), transparent 48%),
    rgba(15, 14, 13, 0.92);
}

.home-survivor-card--r {
  border-color: rgba(95, 90, 82, 0.48);
  border-left-color: var(--metal-light);
}

.home-survivor-card--unavailable {
  opacity: 0.68;
}

.home-survivor-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.home-survivor-copy {
  flex: 1;
  min-width: 0;
}

.home-survivor-name {
  display: block;
  color: var(--base-text);
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.25;
}

.home-survivor-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
  color: rgba(211, 211, 211, 0.76);
  font-size: 23rpx;
  line-height: 1.35;
}

.home-survivor-status {
  box-sizing: border-box;
  flex: 0 0 auto;
  max-width: 180rpx;
  min-height: 38rpx;
  padding: 5rpx 12rpx;
  border: 1rpx solid rgba(57, 255, 20, 0.30);
  border-radius: 8rpx;
  color: var(--radiation-green);
  background: rgba(57, 255, 20, 0.08);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 28rpx;
  text-align: center;
}

.run-overview-card {
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.34);
  border-left: 8rpx solid var(--desert-yellow);
  border-radius: 8rpx;
  background:
    linear-gradient(135deg, rgba(193, 154, 107, 0.13), transparent 52%),
    rgba(15, 14, 13, 0.94);
  box-shadow: 0 16rpx 42rpx rgba(0, 0, 0, 0.32);
}

.run-overview-card--warning {
  border-color: rgba(255, 87, 34, 0.40);
  border-left-color: var(--hazard-orange);
  background:
    linear-gradient(135deg, rgba(139, 58, 58, 0.26), transparent 52%),
    rgba(15, 14, 13, 0.96);
}

.run-overview-card--critical {
  border-color: rgba(255, 106, 106, 0.48);
  border-left-color: #ff6a6a;
  background:
    linear-gradient(135deg, rgba(139, 58, 58, 0.30), transparent 52%),
    rgba(15, 14, 13, 0.96);
}

.run-overview-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.run-overview-kicker {
  display: block;
  color: var(--muted-text);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
}

.run-overview-title {
  display: block;
  margin-top: 6rpx;
  color: var(--base-text);
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.22;
}

.run-overview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.run-overview-item {
  box-sizing: border-box;
  min-height: 112rpx;
  padding: 15rpx 16rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.24);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.22);
}

.run-overview-label {
  display: block;
  color: var(--muted-text);
  font-size: 21rpx;
  line-height: 1.35;
}

.run-overview-value {
  display: block;
  margin-top: 6rpx;
  color: var(--desert-yellow);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.25;
}

.run-overview-helper {
  display: block;
  margin-top: 4rpx;
  color: rgba(211, 211, 211, 0.70);
  font-size: 21rpx;
  line-height: 1.35;
}

.run-overview-note {
  display: block;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(193, 154, 107, 0.18);
  color: rgba(211, 211, 211, 0.84);
  font-size: 25rpx;
  line-height: 1.45;
}

.settlement-message-card {
  border-left-color: var(--desert-yellow);
  background: rgba(193, 154, 107, 0.10);
}

.settlement-title {
  display: block;
  margin-bottom: 8rpx;
  color: var(--desert-yellow);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.4;
}

.resource-status {
  box-sizing: border-box;
  min-height: 44rpx;
  padding: 7rpx 16rpx;
  border-radius: 8rpx;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 30rpx;
  white-space: nowrap;
}

.resource-status--normal {
  border: 1rpx solid rgba(193, 154, 107, 0.30);
  color: var(--desert-yellow);
  background: rgba(193, 154, 107, 0.08);
}

.resource-status--warning {
  border: 1rpx solid rgba(255, 87, 34, 0.34);
  color: var(--hazard-orange);
  background: rgba(255, 87, 34, 0.10);
}

.resource-status--critical {
  border: 1rpx solid rgba(255, 106, 106, 0.44);
  color: #ff7770;
  background: rgba(139, 58, 58, 0.22);
}

.resource-instrument-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.resource-instrument {
  position: relative;
  box-sizing: border-box;
  width: auto;
  min-width: 0;
  min-height: 176rpx;
  padding: 18rpx;
  overflow: hidden;
  border: 1rpx solid rgba(193, 154, 107, 0.26);
  border-radius: 8rpx;
  background:
    linear-gradient(180deg, rgba(95, 90, 82, 0.14), rgba(10, 10, 10, 0.08)),
    rgba(15, 14, 13, 0.92);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.025), 0 12rpx 34rpx rgba(0, 0, 0, 0.30);
}

.resource-instrument::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: rgba(193, 154, 107, 0.42);
}

.resource-instrument--warning {
  border-color: rgba(255, 87, 34, 0.42);
  background:
    linear-gradient(180deg, rgba(255, 87, 34, 0.12), rgba(10, 10, 10, 0.08)),
    rgba(15, 14, 13, 0.92);
}

.resource-instrument--critical {
  border-color: rgba(255, 106, 106, 0.48);
  background:
    linear-gradient(180deg, rgba(139, 58, 58, 0.24), rgba(10, 10, 10, 0.08)),
    rgba(15, 14, 13, 0.94);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.025), 0 0 28rpx rgba(139, 58, 58, 0.20);
}

.resource-instrument--warning::after {
  background: var(--hazard-orange);
}

.resource-instrument--critical::after {
  background: #ff7770;
}

.instrument-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.instrument-code {
  color: var(--muted-text);
  font-size: 20rpx;
  font-weight: 700;
}

.instrument-status {
  color: var(--desert-yellow);
  font-size: 22rpx;
  font-weight: 700;
}

.resource-instrument--warning .instrument-status {
  color: var(--hazard-orange);
}

.resource-instrument--critical .instrument-status {
  color: #ff7770;
}

.resource-instrument .resource-label {
  color: rgba(211, 211, 211, 0.72);
  font-size: 24rpx;
}

.resource-instrument .resource-value {
  margin-top: 6rpx;
  color: var(--base-text);
  font-size: 46rpx;
  line-height: 1.1;
  text-shadow: none;
}

.resource-meter {
  height: 8rpx;
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.08);
}

.resource-meter-fill {
  height: 100%;
  border-radius: 8rpx;
  background: var(--desert-yellow);
}

.resource-meter-fill--warning {
  background: var(--hazard-orange);
}

.resource-meter-fill--critical {
  background: #ff7770;
}

.resource-threshold {
  display: block;
  margin-top: 10rpx;
  color: var(--muted-text);
  font-size: 20rpx;
  line-height: 1.35;
}

.power-shortage-card {
  background:
    linear-gradient(90deg, rgba(139, 58, 58, 0.30), rgba(18, 18, 18, 0.70));
}

.control-button {
  margin-top: 24rpx;
}

.event-card {
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 87, 34, 0.36);
  border-left: 8rpx solid var(--hazard-orange);
  border-radius: 8rpx;
  background:
    linear-gradient(135deg, rgba(139, 58, 58, 0.24), transparent 48%),
    rgba(15, 14, 13, 0.94);
}

.event-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.event-day-label,
.event-priority-label {
  box-sizing: border-box;
  min-height: 38rpx;
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 28rpx;
  white-space: nowrap;
}

.event-day-label {
  border: 1rpx solid rgba(193, 154, 107, 0.30);
  color: var(--desert-yellow);
  background: rgba(193, 154, 107, 0.08);
}

.event-priority-label {
  border: 1rpx solid rgba(255, 87, 34, 0.36);
  color: var(--hazard-orange);
  background: rgba(255, 87, 34, 0.10);
}

.event-title {
  display: block;
  color: var(--base-text);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.event-copy {
  display: block;
  margin-top: 12rpx;
  color: rgba(211, 211, 211, 0.86);
  font-size: 26rpx;
  line-height: 1.55;
}

.event-choice-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}

.event-choice-button {
  box-sizing: border-box;
  width: 100%;
  min-height: 92rpx;
  margin: 0;
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.32);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.24);
  color: var(--base-text);
  line-height: 1.35;
  text-align: left;
}

.event-choice-label {
  display: block;
  color: var(--desert-yellow);
  font-size: 27rpx;
  font-weight: 700;
}

.event-choice-desc {
  display: block;
  margin-top: 6rpx;
  color: rgba(211, 211, 211, 0.78);
  font-size: 23rpx;
  line-height: 1.4;
}

.event-choice-button--active {
  opacity: 0.88;
  transform: translateY(2rpx);
}

.event-choice-button[disabled] {
  border-color: rgba(211, 211, 211, 0.16);
  background: #343434;
  color: rgba(211, 211, 211, 0.58);
}

.offer-card {
  box-sizing: border-box;
  padding: 28rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.34);
  border-left: 8rpx solid var(--rust-red);
  border-radius: 8rpx;
  background:
    linear-gradient(135deg, rgba(139, 58, 58, 0.26), transparent 44%),
    repeating-linear-gradient(90deg, rgba(193, 154, 107, 0.04) 0, rgba(193, 154, 107, 0.04) 1rpx, transparent 1rpx, transparent 18rpx),
    rgba(15, 14, 13, 0.94);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.36);
}

.offer-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.offer-kicker {
  color: var(--desert-yellow);
  font-size: 25rpx;
  font-weight: 700;
}

.offer-badge {
  box-sizing: border-box;
  min-height: 40rpx;
  padding: 5rpx 14rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.34);
  border-radius: 8rpx;
  color: var(--desert-yellow);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 28rpx;
  white-space: nowrap;
}

.offer-title {
  display: block;
  color: var(--base-text);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.offer-copy {
  display: block;
  margin-top: 12rpx;
  color: rgba(211, 211, 211, 0.86);
  font-size: 27rpx;
  line-height: 1.55;
}

.offer-signal-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.offer-signal {
  flex: 1;
  box-sizing: border-box;
  min-height: 82rpx;
  padding: 12rpx 14rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.24);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.20);
}

.offer-signal-label {
  display: block;
  color: var(--muted-text);
  font-size: 21rpx;
}

.offer-signal-value {
  display: block;
  margin-top: 6rpx;
  color: var(--desert-yellow);
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.25;
}

.offer-reward-title {
  display: block;
  margin-top: 20rpx;
  color: rgba(211, 211, 211, 0.86);
  font-size: 24rpx;
  font-weight: 700;
}

.offer-reward-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.offer-reward {
  box-sizing: border-box;
  width: calc(50% - 6rpx);
  min-height: 74rpx;
  padding: 12rpx 14rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.24);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.24);
}

.offer-reward-label {
  display: block;
  color: rgba(211, 211, 211, 0.72);
  font-size: 22rpx;
}

.offer-reward-value {
  display: block;
  margin-top: 4rpx;
  color: var(--desert-yellow);
  font-size: 28rpx;
  font-weight: 700;
}

.offer-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.offer-button-secondary,
.offer-button-primary {
  flex: 1;
  min-height: 76rpx;
  margin: 0;
  padding: 0 12rpx;
  border-radius: 8rpx;
  color: var(--base-text);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.offer-button-secondary {
  border: 1rpx solid rgba(193, 154, 107, 0.34);
  background: rgba(30, 30, 30, 0.84);
}

.offer-button-primary {
  border: 1rpx solid rgba(193, 154, 107, 0.36);
  background: linear-gradient(90deg, var(--rust-red), #4f2323);
}

.offer-button--active {
  opacity: 0.88;
  transform: translateY(2rpx);
}

.offer-button-secondary[disabled],
.offer-button-primary[disabled] {
  border-color: rgba(211, 211, 211, 0.16);
  background: #343434;
  color: rgba(211, 211, 211, 0.58);
}

.debug-section {
  opacity: 0.82;
}

.debug-card {
  box-sizing: border-box;
  padding: 20rpx 22rpx;
  border: 1rpx dashed rgba(193, 154, 107, 0.28);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.18);
}

.debug-helper {
  display: block;
  color: var(--muted-text);
  font-size: 24rpx;
  line-height: 1.5;
}

.debug-helper--spaced {
  margin-top: 22rpx;
}

.debug-mode-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid rgba(193, 154, 107, 0.18);
}

.debug-mode-title {
  display: block;
  color: var(--desert-yellow);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
}

.debug-mode-action {
  flex: 0 0 220rpx;
  text-align: right;
}

.debug-mode-state {
  display: block;
  color: var(--base-text);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
}

.debug-mode-button {
  margin-top: 10rpx;
}

.debug-error {
  display: block;
  margin-top: 8rpx;
  color: var(--hazard-orange);
  font-size: 23rpx;
  line-height: 1.4;
}

.debug-button {
  min-height: 64rpx;
  margin: 18rpx 0 0;
  border: 1rpx solid rgba(193, 154, 107, 0.26);
  border-radius: 8rpx;
  background: rgba(30, 30, 30, 0.72);
  color: var(--muted-text);
  font-size: 24rpx;
  line-height: 64rpx;
}

.debug-button--active {
  opacity: 0.86;
  transform: translateY(2rpx);
}

.debug-button[disabled] {
  border-color: rgba(211, 211, 211, 0.12);
  background: #2a2a2a;
  color: rgba(211, 211, 211, 0.42);
}
