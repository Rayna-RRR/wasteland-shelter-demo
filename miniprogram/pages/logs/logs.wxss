.card + .card {
  margin-top: 16rpx;
}

.log-section {
  position: relative;
}

.log-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid rgba(193, 154, 107, 0.24);
}

.log-section-header .section-title {
  margin-bottom: 0;
}

.log-section-code {
  box-sizing: border-box;
  min-height: 38rpx;
  padding: 5rpx 12rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.30);
  border-radius: 8rpx;
  color: var(--muted-text);
  font-size: 20rpx;
  font-weight: 700;
  line-height: 28rpx;
  white-space: nowrap;
}

.log-card {
  position: relative;
  box-sizing: border-box;
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(193, 154, 107, 0.36);
  border-left: 6rpx solid var(--desert-yellow);
  border-radius: 8rpx;
  background: rgba(18, 18, 18, 0.82);
  box-shadow: 0 12rpx 34rpx rgba(0, 0, 0, 0.28);
}

.log-card::after {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: rgba(193, 154, 107, 0.36);
}

.log-card--gacha {
  border-left-color: var(--desert-yellow);
  background:
    linear-gradient(135deg, rgba(193, 154, 107, 0.10), transparent 44%),
    rgba(18, 18, 18, 0.84);
}

.log-card--duty {
  border-left-color: var(--radiation-green);
  background:
    linear-gradient(135deg, rgba(57, 255, 20, 0.07), transparent 44%),
    rgba(18, 18, 18, 0.84);
}

.log-card--offer {
  border-left-color: var(--hazard-orange);
  background:
    linear-gradient(135deg, rgba(139, 58, 58, 0.18), transparent 44%),
    rgba(18, 18, 18, 0.86);
}

.log-card--rarity-ssr {
  border-color: rgba(255, 87, 34, 0.44);
  border-left-color: var(--hazard-orange);
}

.log-card--rarity-sr {
  border-color: rgba(193, 154, 107, 0.44);
}

.log-card--rarity-r {
  border-color: rgba(95, 90, 82, 0.52);
  border-left-color: var(--metal-light);
}

.log-card--offer-purchased {
  border-left-color: var(--radiation-green);
}

.log-card--offer-closed {
  border-left-color: var(--metal-light);
}

.log-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.log-tag {
  box-sizing: border-box;
  min-height: 38rpx;
  padding: 5rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 28rpx;
  white-space: nowrap;
}

.log-tag--rarity-ssr {
  border: 1rpx solid rgba(255, 87, 34, 0.48);
  background: rgba(255, 87, 34, 0.14);
  color: var(--hazard-orange);
}

.log-tag--rarity-sr {
  border: 1rpx solid rgba(193, 154, 107, 0.48);
  background: rgba(193, 154, 107, 0.12);
  color: var(--desert-yellow);
}

.log-tag--rarity-r {
  border: 1rpx solid rgba(95, 90, 82, 0.56);
  background: rgba(95, 90, 82, 0.12);
  color: var(--muted-text);
}

.log-tag--duty {
  border: 1rpx solid rgba(57, 255, 20, 0.34);
  background: rgba(57, 255, 20, 0.08);
  color: var(--radiation-green);
}

.log-tag--offer-exposed {
  border: 1rpx solid rgba(193, 154, 107, 0.42);
  background: rgba(193, 154, 107, 0.10);
  color: var(--desert-yellow);
}

.log-tag--offer-closed {
  border: 1rpx solid rgba(95, 90, 82, 0.52);
  background: rgba(95, 90, 82, 0.12);
  color: var(--muted-text);
}

.log-tag--offer-purchased {
  border: 1rpx solid rgba(57, 255, 20, 0.36);
  background: rgba(57, 255, 20, 0.09);
  color: var(--radiation-green);
}

.log-time {
  color: var(--muted-text);
  font-size: 22rpx;
  line-height: 1.35;
  text-align: right;
}

.log-title {
  display: block;
  color: var(--base-text);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.log-body {
  display: block;
  margin-top: 12rpx;
  color: rgba(211, 211, 211, 0.86);
  font-size: 26rpx;
  line-height: 1.5;
}

.log-detail-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.log-detail {
  flex: 1;
  box-sizing: border-box;
  padding: 12rpx 14rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.22);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.20);
}

.log-detail-label {
  display: block;
  color: var(--muted-text);
  font-size: 21rpx;
}

.log-detail-value {
  display: block;
  margin-top: 5rpx;
  color: var(--base-text);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.35;
}

.resource-change-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.resource-change {
  box-sizing: border-box;
  padding: 7rpx 12rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.24);
  border-radius: 8rpx;
  color: var(--desert-yellow);
  font-size: 23rpx;
  font-weight: 700;
  line-height: 30rpx;
}

.offer-record-panel {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid rgba(193, 154, 107, 0.22);
  border-radius: 8rpx;
  background: rgba(0, 0, 0, 0.22);
}

.offer-record-line {
  display: block;
  color: rgba(211, 211, 211, 0.84);
  font-size: 25rpx;
  line-height: 1.5;
}

.offer-record-line + .offer-record-line {
  margin-top: 8rpx;
}
